{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "isolatedModules": true }]
  },
  "transformIgnorePatterns": ["node_modules/(?!(puppeteer|puppeteer-core|@puppeteer|devtools-protocol)/)"]
}
