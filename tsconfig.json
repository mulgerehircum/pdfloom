{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  },
  // api/ is Vercel's own serverless-function entry (see api/index.ts) — it imports from
  // dist/, this build's own output, so including it here would be circular: nest build would
  // need dist/ to already exist to typecheck it, before dist/ exists. Vercel's Node.js
  // function bundler compiles it separately and independently at deploy time.
  "exclude": ["node_modules", "dist", "api"]
}
